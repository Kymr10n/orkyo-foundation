{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./.tsbuild",
    "tsBuildInfoFile": "./.tsbuild/.tsbuildinfo",
    "skipLibCheck": true,
    "types": ["vitest/globals", "vite/client", "node"],
    "paths": {
      "@/*": ["./src/*"],
      "@foundation/contracts/*": ["./contracts/*"],
      "@foundation/src/*": ["./src/*"]
    }
  },
  "include": ["contracts/**/*.ts", "src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts", "vitest.config.ts"]
}
