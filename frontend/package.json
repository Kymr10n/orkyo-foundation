{
  "name": "@kymr10n/foundation",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "files": [
    ".tsbuild",
    "assets"
  ],
  "exports": {
    "./src/*": {
      "types": "./.tsbuild/src/*.d.ts",
      "default": "./.tsbuild/src/*.js"
    },
    "./contracts/*": {
      "types": "./.tsbuild/contracts/*.d.ts",
      "default": "./.tsbuild/contracts/*.js"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build && mkdir -p assets && cp -r ../assets/orkyo-favicon-pack/. assets/",
    "build": "tsc -b && tsc-alias -p tsconfig.json && find src -name '*.css' | xargs cp --parents -t .tsbuild/",
    "typecheck": "tsc -b && tsc-alias -p tsconfig.json",
    "test": "vitest run",
    "test:browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:mobile": "playwright test --project=mobile-webkit --project=mobile-chromium --project=tablet-webkit",
    "lint": "eslint src contracts"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-query": ">=5.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@xstate/react": "^6.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^1.8.0",
    "react": ">=19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": ">=19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "xstate": "^5.30.0",
    "zustand": ">=5.0.0"
  },
  "dependencies": {
    "@testing-library/dom": "10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "rrule": "^2.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "happy-dom": "20.10.5",
    "jest-axe": "^9.0.0",
    "tailwindcss": "^4.3.2",
    "tsc-alias": "^1.8.17",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  },
  "overrides": {
    "ws": "^8.21.0",
    "dompurify": "^3.4.10",
    "js-yaml": "^4.2.0"
  }
}
