#!/bin/sh
set -e
REPO_ROOT=$(git rev-parse --show-toplevel)

echo "pre-push: backend format check..."
dotnet format "$REPO_ROOT/Orkyo.Foundation.slnx" --verify-no-changes --no-restore

echo "pre-push: backend build..."
dotnet build "$REPO_ROOT/Orkyo.Foundation.slnx"

echo "pre-push: frontend lint..."
npm run lint --prefix "$REPO_ROOT/frontend"

echo "pre-push: frontend typecheck..."
npm run typecheck --prefix "$REPO_ROOT/frontend"

echo "pre-push: frontend tests..."
npm test --prefix "$REPO_ROOT/frontend" -- --run --coverage --reporter=verbose
